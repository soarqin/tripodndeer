  "stages": [
    {
      "id": "shang_yang_proposal",
      "textZh": "卫鞅自魏来秦，献变法之策于孝公曰：「治世不一道，便国不法古。」其议废井田，开阡陌，立军功，一秦法。朝中守旧之臣议论纷纷，孝公默然。",
      "choices": [
        {
          "id": "adopt",
          "labelZh": "采纳新法",
          "effects": [],
          "nextStageId": "first_law",
          "outcome": "continue"
        },
        {
          "id": "trial",
          "labelZh": "试行于一郡",
          "effects": [],
          "nextStageId": "first_law",
          "outcome": "continue"
        },
        {
          "id": "reject",
          "labelZh": "拒之以安宗室",
          "effects": [],
          "outcome": "failure"
        }
      ],
      "advanceAfterMonths": 12
    },
    {
      "id": "first_law",
      "textZh": "卫鞅徙木立信，赏五十金于市。新法既行，民始畏其令。然旧族窃议曰：「废井田，乱祖制也。」孝公问鞅当何以应之？",
      "choices": [
        {
          "id": "harsh",
          "labelZh": "严刑峻法以立威",
          "effects": [],
          "nextStageId": "noble_resistance",
          "outcome": "continue"
        },
        {
          "id": "gradual",
          "labelZh": "渐进推行",
          "effects": [],
          "nextStageId": "noble_resistance",
          "outcome": "continue"
        },
        {
          "id": "pause",
          "labelZh": "暂缓以待民心",
          "effects": [],
          "outcome": "failure"
        }
      ],
      "advanceAfterMonths": 36
    },
    {
      "id": "noble_resistance",
      "textZh": "贵族怨怼，太子犯法。卫鞅曰：「法之不行，自上犯之。」请刑太子之傅公子虔，黥其师公孙贾。孝公闻之色变，犹豫未决。",
      "choices": [
        {
          "id": "punish_tutors",
          "labelZh": "严惩太子师以彰法",
          "effects": [],
          "nextStageId": "reform_culmination",
          "outcome": "continue"
        },
        {
          "id": "compromise",
          "labelZh": "稍加惩戒以全宗室",
          "effects": [],
          "nextStageId": "reform_culmination",
          "outcome": "continue"
        },
        {
          "id": "yield",
          "labelZh": "退让免罪",
          "effects": [],
          "outcome": "failure"
        }
      ],
      "advanceAfterMonths": 24
    },
    {
      "id": "reform_culmination",
      "textZh": "孝公薨，太子立，是为惠文王。旧族复仇，车裂卫鞅于市。然秦法既立，国势日强，关东诸侯莫敢与之争锋。今当何以处之？",
      "choices": [
        {
          "id": "preserve",
          "labelZh": "维持新法，延续秦制",
          "effects": [],
          "outcome": "success"
        },
        {
          "id": "partial_restore",
          "labelZh": "部分恢复旧制以安宗室",
          "effects": [],
          "outcome": "failure"
        }
